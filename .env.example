# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# Anthropic — required for --provider anthropic (default) and fidelity scoring
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenRouter — required for --provider openrouter
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Simulation Defaults ────────────────────────────────────────────────────────
# Override CLI defaults without passing flags every run
OSE_LOG_DIR=logs/runs
OSE_DEFAULT_TURNS=15
OSE_DEFAULT_TEMPERATURE=0

# Deterministic seed for scenario evolution + perception noise (0 = default)
OSE_SCENARIO_SEED=0
