# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# Anthropic — required for --provider anthropic (default) and fidelity scoring
ANTHROPIC_API_KEY=your_anthropic_key_here
# Optional: override the Anthropic models used for DFS scoring and report analysis
# Anthropic direct API model IDs are Claude-native, e.g. claude-opus-4-6
# OSE_ANALYTICS_MODEL=claude-opus-4-6
# OSE_SCORER_MODEL=claude-opus-4-6
# OSE_ANALYST_MODEL=claude-opus-4-6

# OpenRouter — required for --provider openrouter
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Runtime Defaults ───────────────────────────────────────────────────────────
# Single-run log directory used by `ose` / `ose-run`
OSE_LOG_DIR=logs/runs
# Default turns used by `ose`, `ose-run`, and `experiments.runner`
OSE_DEFAULT_TURNS=15
# Default temperature used by Anthropic/OpenRouter decision calls
OSE_DEFAULT_TEMPERATURE=0
# Default deterministic seed used when `--seed` is omitted
OSE_SCENARIO_SEED=0

# ── Cost / Prompt Verbosity ──────────────────────────────────────────────────
# OSE_PROMPT_MODE controls how much backstory is injected into the system prompt.
#   full    — complete war_aversion / history / constraints / cognitive (~3000 tokens)
#   compact — war_aversion + constraints trimmed; history omitted (~1500 tokens)
#   minimal — only goals, red lines, and doctrine (~800 tokens)
# Use compact or minimal for bulk/exploratory runs; full for final research runs.
# OSE_PROMPT_MODE=compact

# ── OpenRouter Compatibility Tuning (optional) ───────────────────────────────
# Override global output token limit (default: 768)
# OSE_OPENROUTER_MAX_TOKENS=768
# Override json-fallback output limit (default: 256)
# OSE_OPENROUTER_JSON_MAX_TOKENS=256
